{
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "@magneticjs/server",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "module": "ES2020",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["pages", "components", "server"]
}
