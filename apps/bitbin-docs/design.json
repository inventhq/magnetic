{
  "css": "all",
  "theme": {
    "colors": {
      "primary": "#6366f1",
      "primary-hover": "#4f46e5",
      "surface": "#0a0a0a",
      "raised": "#141414",
      "sunken": "#0d0d0d",
      "text": "#e4e4e7",
      "heading": "#ffffff",
      "muted": "#71717a",
      "subtle": "#a1a1aa",
      "border": "#252525",
      "border-hover": "#333333",
      "success": "#22c55e",
      "danger": "#ef4444"
    },
    "spacing": {
      "xs": "0.25rem",
      "sm": "0.5rem",
      "md": "1rem",
      "lg": "1.5rem",
      "xl": "2rem",
      "2xl": "3rem",
      "3xl": "4rem"
    },
    "radius": {
      "sm": "0.375rem",
      "md": "0.625rem",
      "lg": "1rem",
      "full": "9999px"
    },
    "typography": {
      "sans": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
      "mono": "'JetBrains Mono', ui-monospace, 'Cascadia Code', monospace",
      "sizes": {
        "xs": "0.75rem",
        "sm": "0.875rem",
        "base": "1rem",
        "lg": "1.125rem",
        "xl": "1.25rem",
        "2xl": "1.5rem",
        "3xl": "2rem"
      },
      "leading": {
        "tight": "1.25",
        "normal": "1.5",
        "relaxed": "1.75"
      }
    },
    "shadows": {
      "sm": "0 1px 2px rgb(0 0 0 / 0.05)",
      "md": "0 4px 6px rgb(0 0 0 / 0.07), 0 2px 4px rgb(0 0 0 / 0.06)",
      "lg": "0 10px 15px rgb(0 0 0 / 0.1), 0 4px 6px rgb(0 0 0 / 0.05)"
    }
  }
}
